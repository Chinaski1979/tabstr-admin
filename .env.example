# Tabstr registry (central) Supabase project — the SAME project tabstr uses as VITE_REGISTRY_SUPABASE_URL.
# The admin console connects ONLY to the registry. It never connects to per-organization tenant databases.
VITE_REGISTRY_SUPABASE_URL=https://your-registry-project.supabase.co
VITE_REGISTRY_SUPABASE_ANON_KEY=your_registry_anon_key_here

REGISTRY_SERVICE_ROLE_KEY=your_registry_service_role_key_here

# SERVICE_KEY_MI_RESTAURANT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SERVICE_KEY_OTRO_CLIENTE=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SERVICE_KEY_TEST_ORG=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
